{
  "name": "ph-manager",
  "version": "1.0.0",
  "description": "SaaS para administración de Propiedades Horizontales en Panamá",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "cd frontend && npm ci && npm run build",
    "postinstall": "npx prisma generate",
    "start:prod": "npx prisma db push && node src/index.js",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.15.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
