# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente al agregar el plugin de PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/phmanager"

# ── Seguridad ─────────────────────────────────────────────────────────────────
# OBLIGATORIO en producción: mínimo 32 caracteres aleatorios
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_EN_PRODUCCION_minimo_32_chars"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# URL del frontend (para CORS). Dominio público desde donde acceden los usuarios.
FRONTEND_URL=https://www.gestarsoft.com

# ── Archivos subidos ──────────────────────────────────────────────────────────
# En Railway: configurar un Volume montado en /app/uploads y poner la ruta aquí
UPLOADS_DIR=uploads

# ── Registro de nuevos usuarios ───────────────────────────────────────────────
# "true"  → cualquiera puede registrarse (SaaS abierto)
# "false" → registro público deshabilitado; solo admins pueden agregar usuarios
REGISTRO_ABIERTO=false

# ── Bootstrap: primer SUPER_ADMIN ─────────────────────────────────────────────
# Clave para activar /bootstrap una sola vez. Cambiar y mantener en secreto.
BOOTSTRAP_SECRET=cambia-esta-clave-antes-de-produccion

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en https://resend.com — verificar el dominio remitente
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="PH Manager <noreply@tudominio.com>"
